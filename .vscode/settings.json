{
  "github.copilot.chat.mcp.servers": {
    "osticket": {
      "command": "python",
      "args": [
        "${workspaceFolder}/mcp-server/server.py"
      ],
      "env": {
        "OSTICKET_URL": "http://localhost:8080",
