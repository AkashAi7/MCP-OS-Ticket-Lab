# osTicket MCP Server - Environment Configuration
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.

# ------------------------------------------------------------------
# osTicket instance URL (no trailing slash)
# ------------------------------------------------------------------
OSTICKET_URL=http://localhost:8080

# ------------------------------------------------------------------
# Backend selector
#   local  – executes PHP helper scripts inside the Docker container
#            via "docker compose exec" (recommended for local labs)
#   http   – calls the osTicket REST API over HTTP (code default when
#            this variable is not set)
#
# Set to "local" for the local Docker lab (matches .vscode/settings.json).
# Set to "http" when pointing at a remote osTicket instance.
# ------------------------------------------------------------------
OSTICKET_BACKEND=local

# ------------------------------------------------------------------
# API key (required only when OSTICKET_BACKEND=http)
# Generate one in the osTicket Admin Panel:
#   Admin Panel → Manage → API Keys → Add New API Key
# ------------------------------------------------------------------
OSTICKET_API_KEY=your_api_key_here

# ------------------------------------------------------------------
# Local Docker backend settings (only used when OSTICKET_BACKEND=local)
# ------------------------------------------------------------------

# Absolute path to the repository root (where docker-compose.yml lives).
# Defaults to the parent directory of server.py if not set.
# OSTICKET_DOCKER_PROJECT_DIR=/absolute/path/to/MCP-OS-Ticket-Lab

# Path to the Docker executable.
# On Windows, update this to point to your Docker installation.
# Examples:
#   Windows: C:\Program Files\Docker\Docker\resources\bin\docker.exe
#   Linux / macOS: docker   (if docker is on PATH)
DOCKER_EXE=docker
